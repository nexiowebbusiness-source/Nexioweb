<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ESTATE ELITE | Premium Demo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Montserrat:wght@300;400&display=swap" rel="stylesheet">
    <style>
        :root { --gold: #d4af37; }
        body { font-family: 'Montserrat', sans-serif; background: #050505; color: white; margin: 0; }
        .brand { font-family: 'Cinzel', serif; color: var(--gold); }
        .reveal { opacity: 0; transform: translateY(20px); transition: 1s all ease; }
        .reveal.active { opacity: 1; transform: translateY(0); }
        #loader { position: fixed; inset: 0; background: #000; z-index: 99; display: flex; justify-content: center; align-items: center; }
    </style>
</head>
<body>
    <div id="loader"><h2 class="brand animate-pulse uppercase tracking-widest">Loading Experience...</h2></div>

    <nav class="fixed w-full z-50 p-8 flex justify-between items-center bg-gradient-to-b from-black to-transparent">
        <div class="brand text-xl tracking-widest font-bold">ESTATE ELITE</div>
        <div class="space-x-6 text-[10px] uppercase tracking-widest hidden md:block">
            <a href="#" class="hover:text-amber-500">Portfolio</a>
            <a href="#" class="border border-amber-500 px-4 py-2 text-amber-500 hover:bg-amber-500 hover:text-black transition">Inquire Now</a>
        </div>
    </nav>

    <section class="h-screen flex items-center justify-center relative overflow-hidden">
        <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=1920&q=80" class="absolute inset-0 w-full h-full object-cover opacity-40">
        <div class="relative text-center px-4">
            <h1 class="brand text-5xl md:text-8xl mb-6">Masterpieces</h1>
            <p class="text-sm tracking-[0.5em] uppercase opacity-70 mb-10">Bespoke Real Estate Excellence</p>
            <button class="bg-amber-600 text-black px-10 py-4 font-bold uppercase text-xs tracking-widest hover:bg-white transition">Enter The Gallery</button>
        </div>
    </section>

    <section class="py-20 px-10 reveal max-w-5xl mx-auto text-center">
        <h2 class="brand text-4xl mb-6 italic text-amber-500">The Gold Standard</h2>
        <p class="text-gray-400 leading-relaxed">Experience a new era of luxury. We specialize in off-market properties for the world's most discerning clients.</p>
    </section>

    <script>
        window.onload = () => {
            document.getElementById('loader').style.display = 'none';
        };
        const obs = new IntersectionObserver((entries) => {
            entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('active'); });
        });
        document.querySelectorAll('.reveal').forEach(r => obs.observe(r));
    </script>
</body>
</html>
